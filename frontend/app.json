{
  "expo": {
    "name": "Piglytics",
    "slug": "Piglytics",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo1024.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/Piglytics_Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#AAFF00"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo1024.png",
        "backgroundColor": "#AAFF00"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.piglyticscapstone.piglytics"
    },
    "web": {
      "favicon": "./assets/images/logo1024.png"
    },
    "extra": {
      "eas": {
        "projectId": "27608dba-9ad4-4793-a333-eebcaf92a53f"
      }
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}
